# Supabase — used by the "Join the First Adopter Community" waitlist form.
# Create a project at https://supabase.com, then copy these from
# Project Settings → API. Copy this file to `.env` and fill in real values.
#
# The anon (public) key is safe to expose in a browser build *as long as*
# Row Level Security is enabled on the table (see README / supabase/schema.sql).

VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY
